---
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/600.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '../styles/global.css';
import { contact } from '../data/contact';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = '/images/og-default.jpg',
  noindex = false,
} = Astro.props;

const siteUrl = 'https://www.lenz-wohntex.de';
const canonicalURL = canonical ?? new URL(Astro.url.pathname, siteUrl).href;

const schemaOrg = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  '@id': siteUrl,
  name: contact.company,
  description:
    'Raumausstatter in Michelfeld bei Schwäbisch Hall – Gardinen, Bodenbeläge, Sonnenschutz und Insektenschutz seit 1985.',
  url: siteUrl,
  telephone: contact.phonePlain,
  address: {
    '@type': 'PostalAddress',
    streetAddress: contact.street,
    addressLocality: contact.city,
    postalCode: contact.zip,
    addressCountry: 'DE',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Wednesday', 'Saturday'],
      opens: '09:00',
      closes: '12:30',
    },
  ],
  areaServed: contact.regions,
  foundingDate: contact.founded,
  priceRange: '€€',
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl).href} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Lenz Wohntex" />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />

    <!-- Cookie-Banner -->
    <div class="cookie-banner" id="cookie-banner" role="region" aria-label="Cookie-Hinweis">
      <p class="cookie-banner__text">
        Diese Website verwendet ausschließlich technisch notwendige Cookies.
        <a href="/datenschutz/">Datenschutzerklärung</a>
      </p>
      <div class="cookie-banner__actions">
        <button
          class="btn btn--ghost"
          id="cookie-reject"
          style="padding: 0.5rem 1rem; font-size: 0.8125rem;"
        >
          Ablehnen
        </button>
        <button
          class="btn btn--primary"
          id="cookie-accept"
          style="padding: 0.5rem 1rem; font-size: 0.8125rem;"
        >
          Verstanden
        </button>
      </div>
    </div>

    <script>
      // Header: Scroll-Schatten
      const header = document.querySelector('.site-header');
      if (header) {
        window.addEventListener(
          'scroll',
          () => header.classList.toggle('is-scrolled', window.scrollY > 20),
          { passive: true }
        );
      }

      // Mobile-Menü
      const menuToggle = document.getElementById('menu-toggle');
      const mobileNav  = document.getElementById('mobile-nav');
      const mobileClose = document.getElementById('mobile-close');

      menuToggle?.addEventListener('click', () => {
        mobileNav?.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        menuToggle.setAttribute('aria-expanded', 'true');
      });

      function closeMenu() {
        mobileNav?.classList.remove('is-open');
        document.body.style.overflow = '';
        menuToggle?.setAttribute('aria-expanded', 'false');
      }

      mobileClose?.addEventListener('click', closeMenu);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMenu();
      });

      // Scroll Reveal via IntersectionObserver
      const revealEls = document.querySelectorAll('.reveal');
      if (revealEls.length > 0 && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        revealEls.forEach((el) => io.observe(el));
      } else {
        // Fallback: kein JS / alter Browser → sofort sichtbar
        revealEls.forEach((el) => el.classList.add('is-visible'));
      }

      // Cookie-Banner
      const banner = document.getElementById('cookie-banner');
      if (banner && localStorage.getItem('cookies-decision') !== null) {
        banner.hidden = true;
      }

      document.getElementById('cookie-accept')?.addEventListener('click', () => {
        localStorage.setItem('cookies-decision', 'accepted');
        if (banner) banner.hidden = true;
      });

      document.getElementById('cookie-reject')?.addEventListener('click', () => {
        localStorage.setItem('cookies-decision', 'rejected');
        if (banner) banner.hidden = true;
      });
    </script>
  </body>
</html>
