---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import ContactStrip from '../../components/sections/ContactStrip.astro';
---

<PageLayout
  title="Bodenbeläge Schwäbisch Hall – Parkett, Vinyl, Laminat & Teppich | Lenz Wohntex"
  description="Parkett, Vinyl, Laminat, Teppich und Kork – breite Musterauswahl im Showroom Michelfeld. Fachgerechte Verlegung durch unser Team in der Region Schwäbisch Hall."
>
  <div class="page-hero">
    <div class="container">
      <Breadcrumb crumbs={[
        { label: 'Startseite', href: '/' },
        { label: 'Leistungen', href: '/leistungen/' },
        { label: 'Bodenbeläge' },
      ]} />
      <span class="page-hero__eyebrow">Leistungen</span>
      <h1 class="page-hero__title">Bodenbeläge</h1>
      <p class="page-hero__lead">
        Der richtige Boden macht den Raum. Ob Parkett, Vinyl, Laminat, Teppich oder Kork –
        in unserem Showroom in Michelfeld sehen Sie die Unterschiede, wir beraten Sie ehrlich
        und verlegen professionell.
      </p>
    </div>
  </div>

  <!-- Produktbereiche -->
  <section class="section">
    <div class="container">
      <span class="section__label">Unser Sortiment</span>
      <h2 class="section__title">Welcher Boden passt zu Ihnen?</h2>
      <p class="section__lead">
        Wir führen alle gängigen Bodenbeläge und helfen Ihnen, den richtigen für
        Ihre Anforderungen, Ihren Stil und Ihr Budget zu finden.
      </p>

      <div class="grid-features">
        {[
          {
            title: 'Vinyl & Designbeläge (LVT)',
            text: 'Vinyl-Designbeläge sind die moderne Alternative zu Echtholz und Naturstein. Sie sind strapazierfähig, feuchtigkeitsresistent und leicht zu pflegen – und damit ideal für Küche, Bad, Keller und stark beanspruchte Bereiche. Erhältlich in Holz-, Stein- und Betonoptik.',
            tags: ['Wasserfest', 'Pflegeleicht', 'Küche & Bad', 'Klickverlegung'],
          },
          {
            title: 'Fertigparkett',
            text: 'Fertigparkett bringt die Wärme und Natürlichkeit von Echtholz in Ihren Wohnraum. Bei uns finden Sie über 50 Dekore in verschiedenen Holzarten, Oberflächenstrukturen und Formaten. Langlebig, werthaltig und nachschleifbar.',
            tags: ['Echtholz', '50+ Dekore', 'Nachschleifbar', 'Wohnzimmer'],
          },
          {
            title: 'Laminat',
            text: 'Laminat bietet die Optik von Holz oder Stein bei sehr guter Pflegeleichtigkeit und günstigem Preis. Die Klickverlegung geht schnell und kann auf vorhandenen Unterboden aufgebracht werden. Ideal für Schlafzimmer und Flure.',
            tags: ['Pflegeleicht', 'Klickverlegung', 'Preiswert'],
          },
          {
            title: 'Teppichboden',
            text: 'Teppichböden sorgen für Wärme, Gemütlichkeit und wirken schalldämmend. Von kurzem Velours bis zum langen Shaggy-Flor – wir führen ein breites Sortiment für Schlafzimmer, Kinderzimmer und Wohnräume. Auch in strapazierfahigen Ausführungen für Flure erhältlich.',
            tags: ['Wärme', 'Schalldämmung', 'Schlafzimmer', 'Kinderzimmer'],
          },
          {
            title: 'Korkboden',
            text: 'Kork ist ein natürlicher, nachwachsender Rohstoff mit hervorragenden Eigenschaften: er wirkt wärmend, ist trittelastisch, schallabsorbierend und angenehm unter nackten Füßen. Ideal für Schlafzimmer, Kinderzimmer und Heimarbeitsplätze.',
            tags: ['Natürlich', 'Trittelastisch', 'Wärmend', 'Allergikerfreundlich'],
          },
        ].map((item) => (
          <div class="feature-item">
            <h3 class="feature-item__title">{item.title}</h3>
            <p class="feature-item__text">{item.text}</p>
            <div class="feature-item__tags">
              {item.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Verlegung -->
  <section class="section section--alt">
    <div class="container container--narrow">
      <span class="section__label">Handwerk</span>
      <h2 class="section__title">Professionelle Verlegung</h2>
      <p style="color:var(--clr-text-secondary);line-height:1.75;margin-bottom:var(--sp-6);">
        Ein neuer Boden ist nur so gut wie seine Verlegung. Deshalb übernehmen wir den
        gesamten Prozess – von der Untergrundprüfung bis zur Leistenmontage:
      </p>
      <ul style="display:flex;flex-direction:column;gap:var(--sp-3);">
        {[
          'Kontrolle und Vorbereitung des Untergrunds',
          'Ausgleich von Unebenheiten bei Bedarf',
          'Fachgerechte Verlegung nach Herstellervorgabe',
          'Montage von Sockelleisten und Übergangsprofilen',
          'Saubere Abschlüsse an Türen, Heizungsrohren und Wänden',
          'Sorgfältige Entsorgung des Verpackungsmaterials',
        ].map((item) => (
          <li style="display:flex;align-items:flex-start;gap:var(--sp-3);color:var(--clr-text-secondary);font-size:var(--text-sm);">
            <svg width="16" height="16" fill="none" stroke="var(--clr-accent)" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true" style="flex-shrink:0;margin-top:0.2em;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <ContactStrip />
</PageLayout>
