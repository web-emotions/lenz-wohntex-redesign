---
import { navigation } from '../../data/navigation';
import { contact } from '../../data/contact';

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="container">
    <div class="header-inner">

      <!-- Logo -->
      <a href="/" class="site-logo" aria-label="Lenz Wohntex – zur Startseite">
        <img
          src="/images/Logo Lenz Wohntex/lenzwohntex.png"
          alt="Lenz Wohntex"
          width="180"
          height="44"
          loading="eager"
          class="site-logo__img"
        />
      </a>

      <!-- Desktop-Navigation -->
      <nav class="site-nav" aria-label="Hauptnavigation">
        <ul class="site-nav__list">
          {navigation.main.map((item) => (
            <li class={`site-nav__item ${'children' in item ? 'has-dropdown' : ''}`}>
              <a
                href={item.href}
                class="site-nav__link"
                aria-current={isActive(item.href) ? 'page' : undefined}
                aria-haspopup={'children' in item ? 'true' : undefined}
              >
                {item.label}
                {'children' in item && (
                  <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true" style="margin-left:2px;opacity:0.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                )}
              </a>
              {'children' in item && (
                <ul class="site-nav__dropdown" role="menu">
                  {item.children.map((child) => (
                    <li role="none">
                      <a
                        href={child.href}
                        class="site-nav__dropdown-link"
                        role="menuitem"
                        aria-current={isActive(child.href) ? 'page' : undefined}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </nav>

      <!-- Rechte Seite: Telefon + Hamburger -->
      <div style="display:flex;align-items:center;gap:0.75rem;">
        <a
          href={`tel:${contact.phonePlain}`}
          class="header-phone"
          aria-label={`Jetzt anrufen: ${contact.phone}`}
        >
          <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          {contact.phone}
        </a>

        <button
          class="menu-toggle"
          id="menu-toggle"
          aria-label="Menü öffnen"
          aria-expanded="false"
          aria-controls="mobile-nav"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

    </div>
  </div>
</header>

<!-- Mobile-Navigation -->
<nav
  class="mobile-nav"
  id="mobile-nav"
  aria-label="Mobile Navigation"
  aria-hidden="true"
>
  <div class="container" style="width:100%;">
    <div class="mobile-nav__header">
      <a href="/" class="site-logo" aria-label="Lenz Wohntex – zur Startseite">
        <img
          src="/images/Logo Lenz Wohntex/lenzwohntex.png"
          alt="Lenz Wohntex"
          width="180"
          height="44"
          loading="eager"
          style="height:38px;width:auto;display:block;"
        />
      </a>
      <button class="mobile-nav__close" id="mobile-close" aria-label="Menü schließen">
        <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <ul class="mobile-nav__list">
      <li>
        <a href="/" class="mobile-nav__link">Startseite</a>
      </li>
      {navigation.main.map((item) => (
        <li>
          <a href={item.href} class="mobile-nav__link">{item.label}</a>
          {'children' in item && (
            <div class="mobile-nav__sub">
              {item.children.map((child) => (
                <a href={child.href} class="mobile-nav__sub-link">{child.label}</a>
              ))}
            </div>
          )}
        </li>
      ))}
      <li>
        <a href="/kontakt/" class="mobile-nav__link">Kontakt</a>
      </li>
    </ul>

    <a href={`tel:${contact.phonePlain}`} class="mobile-nav__phone">
      {contact.phone}
    </a>
  </div>
</nav>
