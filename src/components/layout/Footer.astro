---
import { navigation } from '../../data/navigation';
import { contact } from '../../data/contact';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">

      <!-- Spalte 1: Unternehmen -->
      <div>
        <p class="footer-logo">Lenz Wohntex</p>
        <p class="footer-tagline">
          Ihr Raumausstatter in Michelfeld seit 1985.<br />
          Gardinen, Bodenbeläge, Sonnenschutz<br />
          und Insektenschutz – persönlich und regional.
        </p>
        <a
          href={`tel:${contact.phonePlain}`}
          style="display:inline-flex;align-items:center;gap:0.5rem;color:var(--clr-accent);font-weight:700;font-size:1.125rem;transition:color 180ms ease;"
        >
          <svg width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          {contact.phone}
        </a>
      </div>

      <!-- Spalte 2: Navigation -->
      <div>
        <p class="footer-section__title">Navigation</p>
        <nav class="footer-nav" aria-label="Footer-Navigation">
          <a href="/">Startseite</a>
          {navigation.main.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
          <a href="/kontakt/">Kontakt</a>
        </nav>
      </div>

      <!-- Spalte 3: Kontakt & Öffnungszeiten -->
      <div>
        <p class="footer-section__title">Kontakt & Öffnungszeiten</p>
        <div class="footer-contact">
          <p>
            {contact.street}<br />
            {contact.zip} {contact.city}
          </p>
          <p>
            <a href={`tel:${contact.phonePlain}`}>{contact.phone}</a>
          </p>
          <p>
            <a href={`mailto:${contact.email}`}>{contact.email}</a>
          </p>
        </div>
        <dl class="footer-hours">
          {contact.hours.map((h) => (
            <>
              <dt>{h.days}</dt>
              <dd>{h.time}</dd>
            </>
          ))}
        </dl>
      </div>

    </div>

    <!-- Footer-Bottom -->
    <div class="footer-bottom">
      <p class="footer-copyright">© {year} {contact.company}, {contact.city}</p>
      <nav class="footer-legal" aria-label="Rechtliche Links">
        {navigation.secondary.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>
